<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>ExamForge - Online Exam Portal</title>
<!-- Modern Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
:root {
  /* Premium Dark Glassmorphism Theme */
  --bg: #09090b; /* zinc-950 */
  --bg2: #18181b; /* zinc-900 */
  --card: rgba(24, 24, 27, 0.6); 
  --card-border: rgba(255, 255, 255, 0.08);
  --elevated: rgba(39, 39, 42, 0.8);
  --input: rgba(0, 0, 0, 0.3);
  
  --accent: #6366f1; /* Indigo 500 */
  --accent-h: #818cf8;
  --accent-glow: rgba(99, 102, 241, 0.4);
  --accent-grad: linear-gradient(135deg, #6366f1, #a855f7);
  
  --success: #10b981; 
  --success-l: rgba(16, 185, 129, 0.15);
  --warn: #f59e0b; 
  --warn-l: rgba(245, 158, 11, 0.15);
  --danger: #ef4444;
  --danger-l: rgba(239, 68, 68, 0.15);
  
  --txt: #f4f4f5; 
  --txt2: #a1a1aa; 
  --muted: #52525b;
  
  --r-sm: 8px; --r: 12px; --r-lg: 16px; --r-xl: 24px;
  --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  --font-main: 'Plus Jakarta Sans', sans-serif;
  --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

html { scroll-behavior: smooth; }
body { 
  font-family: var(--font-main); 
  background: var(--bg); 
  color: var(--txt); 
  min-height: 100vh; 
  line-height: 1.6; 
  overflow-x: hidden;
  position: relative;
}

/* Beautiful Animated Background Mesh */
body::before {
  content: '';
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  background: 
    radial-gradient(circle at 15% 50%, rgba(99, 102, 241, 0.08) 0%, transparent 40%),
    radial-gradient(circle at 85% 30%, rgba(168, 85, 247, 0.08) 0%, transparent 40%);
  z-index: -1;
  pointer-events: none;
}

/* Base Elements */
h1,h2,h3,h4,h5 { font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; }
a { color: var(--accent); text-decoration: none; }

::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 4px; }

/* Utilities */
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.flex { display: flex; }
.gap-1 { gap: 8px; } .gap-2 { gap: 16px; } .gap-3 { gap: 24px; }
.items-center { align-items: center; } .justify-between { justify-content: space-between; }
.text-center { text-align: center; }
.mt-1 { margin-top: 8px; } .mt-2 { margin-top: 16px; } .mt-3 { margin-top: 24px; } .mb-3 { margin-bottom: 24px; }
.w-full { width: 100%; }
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
@media(max-width: 768px){ .grid-2, .grid-3 { grid-template-columns: 1fr; } }
.hidden { display: none !important; }

/* Buttons */
.btn { 
  display: inline-flex; align-items: center; justify-content: center; gap: 8px; 
  padding: 10px 20px; border: none; border-radius: var(--r-sm); 
  font-family: inherit; font-size: 14px; font-weight: 600; 
  cursor: pointer; transition: all var(--transition); 
  white-space: nowrap; position: relative; overflow: hidden;
}
.btn:active { transform: translateY(1px); }
.btn-primary { 
  background: var(--accent-grad); color: #fff; 
  box-shadow: 0 4px 12px var(--accent-glow); 
}
.btn-primary:hover { box-shadow: 0 6px 20px var(--accent-glow); transform: translateY(-2px); }
.btn-secondary { background: var(--elevated); color: var(--txt); border: 1px solid var(--card-border); }
.btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }
.btn-success { background: var(--success); color: #fff; }
.btn-success:hover { background: #059669; }
.btn-danger { background: var(--danger); color: #fff; }
.btn-danger:hover { background: #dc2626; }
.btn-sm { padding: 8px 14px; font-size: 13px; }
.btn-lg { padding: 14px 32px; font-size: 16px; border-radius: var(--r); }
.btn-ghost { background: transparent; color: var(--txt2); }
.btn-ghost:hover { color: var(--txt); background: var(--elevated); }
.btn-icon { width: 36px; height: 36px; padding: 0; }

/* Cards (Glassmorphism) */
.card { 
  background: var(--card); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--card-border); border-radius: var(--r-lg); 
  padding: 24px; transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); 
}
.card:hover { border-color: rgba(255, 255, 255, 0.15); box-shadow: var(--shadow); }
.card-glow { position: relative; }
.card-glow::after {
  content: ''; position: absolute; inset: -1px; border-radius: inherit; z-index: -1;
  background: var(--accent-grad); opacity: 0.15; filter: blur(10px);
}

/* Inputs */
.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--txt2); margin-bottom: 6px; }
.input, .textarea, .select { 
  width: 100%; padding: 12px 16px; background: var(--input); 
  border: 1px solid var(--card-border); border-radius: var(--r-sm); 
  color: var(--txt); font-family: inherit; font-size: 14px; 
  transition: all var(--transition); outline: none; 
}
.input:focus, .textarea:focus, .select:focus { border-color: var(--accent); background: rgba(0,0,0,0.5); box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2); }
.textarea { resize: vertical; min-height: 80px; }

/* Navbar */
.nav { 
  position: sticky; top: 0; z-index: 100; 
  background: rgba(9, 9, 11, 0.8); backdrop-filter: blur(16px); 
  border-bottom: 1px solid var(--card-border); padding: 0 24px; 
  height: 70px; display: flex; align-items: center; justify-content: space-between; 
}
.nav-brand { font-size: 20px; font-weight: 700; color: var(--txt); display: flex; align-items: center; gap: 10px; }
.nav-brand i { background: var(--accent-grad); -webkit-background-clip: text; color: transparent; font-size: 22px; }
.nav-links { display: flex; gap: 8px; }
.nav-link { padding: 8px 16px; border-radius: var(--r-sm); font-size: 14px; font-weight: 600; color: var(--txt2); cursor: pointer; transition: all var(--transition); border: none; background: none; }
.nav-link:hover, .nav-link.active { color: var(--txt); background: var(--elevated); }
.nav-link.active { color: var(--accent); }
.nav-user { display: flex; align-items: center; gap: 16px; }
.nav-user-info { font-size: 13px; color: var(--txt2); text-align: right; }
.nav-user-info strong { color: var(--txt); font-weight: 600; display: block; }
.nav-role { font-size: 11px; padding: 2px 8px; border-radius: 99px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.nav-role.admin { background: var(--accent-glow); color: #fff; }
.nav-role.student { background: var(--success-l); color: var(--success); }

/* Views & Animation */
.view { display: none; animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1); padding: 40px 0; min-height: calc(100vh - 70px); }
.view.active { display: block; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

/* Auth Layout */
.auth-wrap { max-width: 420px; margin: 60px auto; }
.auth-tabs { display: flex; margin-bottom: 32px; background: rgba(0,0,0,0.3); padding: 6px; border-radius: var(--r); border: 1px solid var(--card-border); }
.auth-tab { flex: 1; padding: 10px; text-align: center; border-radius: var(--r-sm); font-weight: 600; font-size: 14px; cursor: pointer; transition: all var(--transition); border: none; background: none; color: var(--txt2); }
.auth-tab.active { background: var(--elevated); color: var(--txt); box-shadow: var(--shadow); }
.auth-form { display: none; } .auth-form.active { display: block; animation: fadeUp 0.3s ease; }
.seed-info { margin-top: 24px; padding: 16px; background: rgba(245, 158, 11, 0.1); border-radius: var(--r); border: 1px dashed rgba(245, 158, 11, 0.4); font-size: 13px; color: var(--txt2); }
.seed-info strong { color: var(--warn); }

/* Dashboard Components */
.stat-card { text-align: center; padding: 32px 20px; }
.stat-card .stat-icon { width: 56px; height: 56px; border-radius: var(--r-lg); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 24px; }
.stat-card .stat-val { font-size: 36px; font-weight: 700; margin-bottom: 4px; letter-spacing: -1px; }
.stat-card .stat-label { font-size: 13px; color: var(--txt2); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

/* Table */
.table-wrap { overflow-x: auto; border-radius: var(--r-lg); border: 1px solid var(--card-border); background: var(--card); }
table { width: 100%; border-collapse: collapse; }
th, td { padding: 16px; text-align: left; border-bottom: 1px solid var(--card-border); font-size: 14px; }
th { background: rgba(0,0,0,0.2); font-weight: 600; color: var(--txt2); text-transform: uppercase; font-size: 12px; letter-spacing: 0.5px; }
tr:hover td { background: rgba(255,255,255,0.02); }
tr:last-child td { border-bottom: none; }

/* Badges */
.badge { display: inline-block; padding: 4px 12px; border-radius: 99px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.badge-active { background: var(--success-l); color: var(--success); }
.badge-inactive { background: var(--danger-l); color: var(--danger); }
.badge-pass { background: var(--success-l); color: var(--success); }
.badge-fail { background: var(--danger-l); color: var(--danger); }

/* Exam Listing Cards */
.exam-card { display: flex; justify-content: space-between; align-items: center; gap: 20px; padding: 24px; cursor: default; margin-bottom: 12px; }
.exam-card .exam-info h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
.exam-card .exam-meta { display: flex; gap: 16px; font-size: 13px; color: var(--txt2); flex-wrap: wrap; align-items: center; }
.exam-card .exam-meta span { display: flex; align-items: center; gap: 6px; }
.exam-card .exam-actions { display: flex; gap: 8px; flex-shrink: 0; }

/* Exam Taking UI */
.exam-header { display: flex; justify-content: space-between; align-items: center; padding: 24px; background: var(--card); border: 1px solid var(--card-border); border-radius: var(--r-lg); margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
.exam-header .timer { font-size: 28px; font-weight: 700; padding: 10px 24px; border-radius: var(--r-sm); background: rgba(0,0,0,0.4); display: flex; align-items: center; gap: 12px; border: 1px solid var(--card-border); }
.exam-header .timer.warning { color: var(--warn); border-color: var(--warn); box-shadow: 0 0 20px var(--warn-l); }
.exam-header .timer.danger { color: var(--danger); border-color: var(--danger); animation: pulseDanger 1s infinite; }
@keyframes pulseDanger { 0%,100%{ box-shadow: 0 0 0 var(--danger-l); } 50%{ box-shadow: 0 0 20px var(--danger); } }

.exam-body { display: grid; grid-template-columns: 260px 1fr; gap: 24px; }
@media(max-width: 768px){ .exam-body { grid-template-columns: 1fr; } }
.q-nav { background: var(--card); border: 1px solid var(--card-border); border-radius: var(--r-lg); padding: 24px; align-self: start; position: sticky; top: 90px; }
.q-nav-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 16px; }
.q-nav-btn { width: 100%; aspect-ratio: 1; border: 1px solid var(--card-border); background: var(--input); color: var(--txt2); border-radius: var(--r-sm); font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
.q-nav-btn:hover { border-color: var(--accent); color: var(--txt); }
.q-nav-btn.current { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 0 12px var(--accent-glow); }
.q-nav-btn.answered { background: var(--success-l); color: var(--success); border-color: var(--success); }
.q-nav-btn.flagged { background: var(--warn-l); color: var(--warn); border-color: var(--warn); }

.q-display { background: var(--card); border: 1px solid var(--card-border); border-radius: var(--r-lg); padding: 32px; }
.q-title { font-size: 20px; font-weight: 600; margin-bottom: 32px; line-height: 1.5; }
.option-item { display: flex; align-items: center; gap: 16px; padding: 16px 20px; background: rgba(0,0,0,0.2); border: 1px solid var(--card-border); border-radius: var(--r-sm); cursor: pointer; transition: all 0.2s; margin-bottom: 12px; font-size: 15px; }
.option-item:hover { border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.03); }
.option-item.selected { border-color: var(--accent); background: rgba(99,102,241,0.1); }
.option-radio { width: 20px; height: 20px; border: 2px solid var(--muted); border-radius: 50%; flex-shrink: 0; transition: all 0.2s; position: relative; }
.option-item.selected .option-radio { border-color: var(--accent); }
.option-item.selected .option-radio::after { content: ''; position: absolute; inset: 3px; border-radius: 50%; background: var(--accent); }
.q-nav-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--card-border); }

/* Results Component */
.result-hero { text-align: center; padding: 56px 24px; background: var(--card); border: 1px solid var(--card-border); border-radius: var(--r-xl); margin-bottom: 32px; }
.score-circle { width: 180px; height: 180px; border-radius: 50%; margin: 0 auto 24px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
.score-circle svg { position: absolute; inset: 0; width: 100%; height: 100%; transform: rotate(-90deg); }
.score-circle circle { fill: none; stroke-width: 8; stroke-linecap: round; }
.score-circle .bg-ring { stroke: var(--card-border); }
.score-circle .fg-ring { stroke: var(--success); transition: stroke-dashoffset 2s cubic-bezier(0.2, 1, 0.3, 1); }
.score-circle .fg-ring.fail { stroke: var(--danger); }
.score-val { font-size: 48px; font-weight: 700; line-height: 1; }
.result-status { font-size: 28px; font-weight: 700; margin-bottom: 8px; letter-spacing: 1px; text-transform: uppercase; }
.result-status.pass { color: var(--success); } .result-status.fail { color: var(--danger); }

/* Toasts & Modals */
.toast-wrap { position: fixed; top: 20px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 12px; }
.toast { padding: 16px 24px; border-radius: var(--r-sm); font-size: 14px; font-weight: 600; animation: slideIn 0.3s cubic-bezier(0.16,1,0.3,1); display: flex; align-items: center; gap: 12px; backdrop-filter: blur(12px); box-shadow: var(--shadow); }
.toast.success { background: rgba(16, 185, 129, 0.2); border: 1px solid var(--success); color: #fff; }
.toast.error { background: rgba(239, 68, 68, 0.2); border: 1px solid var(--danger); color: #fff; }
.toast.info { background: rgba(99, 102, 241, 0.2); border: 1px solid var(--accent); color: #fff; }

@keyframes slideIn { from { opacity: 0; transform: translateX(50px); } to { opacity: 1; transform: translateX(0); } }

.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 5000; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.2s ease; padding: 24px; }
.modal-box { background: var(--bg2); border: 1px solid var(--card-border); border-radius: var(--r-lg); padding: 32px; max-width: 480px; width: 100%; box-shadow: var(--shadow); animation: scaleIn 0.25s cubic-bezier(0.16,1,0.3,1); }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes scaleIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }

.modal-box h3 { font-size: 22px; margin-bottom: 12px; }
.modal-box p { color: var(--txt2); margin-bottom: 24px; }
.modal-actions { display: flex; gap: 12px; justify-content: flex-end; }
</style>
</head>
<body>

<!-- Toast Container -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- Modal Container -->
<div id="modalWrap"></div>

<!-- Navigation -->
<nav class="nav hidden" id="mainNav">
  <div class="nav-brand"><i class="fas fa-cube"></i> ExamForge</div>
  <div class="nav-links" id="navLinks"></div>
  <div class="nav-user">
    <div class="nav-user-info"><strong id="navName"></strong><span class="nav-role" id="navRole"></span></div>
    <button class="btn btn-sm btn-secondary btn-icon" onclick="App.logout()" title="Logout"><i class="fas fa-sign-out-alt"></i></button>
  </div>
</nav>

<!-- ═══ AUTH VIEW ═══ -->
<section class="view active" id="view-auth">
  <div class="auth-wrap card card-glow">
    <div style="text-align:center;margin-bottom:32px">
      <div style="font-size:42px; background: var(--accent-grad); -webkit-background-clip: text; color: transparent; margin-bottom:12px"><i class="fas fa-cube"></i></div>
      <h1 style="font-size: 28px; margin-bottom: 8px;">Welcome to ExamForge</h1>
      <p style="color:var(--txt2)">Create and conquer assessments</p>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab active" onclick="App.switchAuth('login')">Sign In</button>
      <button class="auth-tab" onclick="App.switchAuth('register')">Sign Up</button>
    </div>
    <form class="auth-form active" id="form-login" onsubmit="App.login(event)">
      <div class="form-group"><label>Email</label><input class="input" type="email" id="loginEmail" required placeholder="you@example.com"></div>
      <div class="form-group"><label>Password</label><input class="input" type="password" id="loginPass" required placeholder="••••••••"></div>
      <button class="btn btn-primary w-full mt-2" type="submit" style="padding: 12px">Sign In</button>
    </form>
    <form class="auth-form" id="form-register" onsubmit="App.register(event)">
      <div class="form-group"><label>Full Name</label><input class="input" type="text" id="regName" required placeholder="John Doe"></div>
      <div class="form-group"><label>Email</label><input class="input" type="email" id="regEmail" required placeholder="you@example.com"></div>
      <div class="form-group"><label>Password</label><input class="input" type="password" id="regPass" required placeholder="Min 4 characters"></div>
      <div class="form-group"><label>Role</label>
        <select class="select" id="regRole">
          <option value="student">Student</option>
          <option value="admin">Admin / Teacher</option>
        </select>
      </div>
      <button class="btn btn-primary w-full mt-2" type="submit" style="padding: 12px">Create Account</button>
    </form>
    <div class="seed-info">
      <strong>Quick Start:</strong> Click to seed demo data.<br><br>
      Admin: <code>admin@exam.com / admin123</code><br>
      Student: <code>student@exam.com / student123</code>
      <div class="mt-2"><button class="btn btn-sm btn-secondary w-full" onclick="App.seed()"><i class="fas fa-database"></i> Seed Demo Data</button></div>
    </div>
  </div>
</section>

<!-- ═══ ADMIN DASHBOARD ═══ -->
<section class="view" id="view-admin">
  <div class="container">
    <div class="flex justify-between items-center mb-3">
      <div><h2 style="font-size:32px;">Admin Dashboard</h2><p style="color:var(--txt2)">Manage exams and monitor performance</p></div>
      <button class="btn btn-primary" onclick="App.showCreateExam()"><i class="fas fa-plus"></i> Create Exam</button>
    </div>
    <div class="grid-3 mb-3" id="adminStats"></div>
    <h3 style="font-size:20px; margin-bottom:16px;">Your Exams</h3>
    <div id="adminExamList"></div>
  </div>
</section>

<!-- ═══ ADMIN CREATE EXAM ═══ -->
<section class="view" id="view-admin-create">
  <div class="container" style="max-width:600px">
    <button class="btn btn-ghost mb-3" onclick="App.navigate('admin')"><i class="fas fa-arrow-left"></i> Back</button>
    <h2 style="font-size:28px; margin-bottom:24px">Create New Exam</h2>
    <form class="card" onsubmit="App.createExam(event)">
      <div class="form-group"><label>Exam Title</label><input class="input" id="examTitle" required placeholder="e.g. Advanced JavaScript"></div>
      <div class="form-group"><label>Description</label><textarea class="textarea" id="examDesc" placeholder="Brief description..."></textarea></div>
      <div class="grid-2">
        <div class="form-group"><label>Duration (minutes)</label><input class="input" type="number" id="examDuration" required min="1" value="30"></div>
        <div class="form-group"><label>Passing %</label><input class="input" type="number" id="examPassPct" min="0" max="100" value="40"></div>
      </div>
      <button class="btn btn-primary w-full mt-2" type="submit" style="padding: 12px">Create Exam</button>
    </form>
  </div>
</section>

<!-- ═══ ADMIN EXAM DETAIL ═══ -->
<section class="view" id="view-admin-exam">
  <div class="container">
    <button class="btn btn-ghost mb-3" onclick="App.navigate('admin')"><i class="fas fa-arrow-left"></i> Back to Dashboard</button>
    <div id="adminExamHeader"></div>
    <div class="exam-body" style="grid-template-columns: 1fr 380px; margin-top:24px">
      <div>
        <div class="flex justify-between items-center mb-2"><h3 style="font-size:20px;">Questions</h3><span id="qCountLabel" style="color:var(--txt2)"></span></div>
        <div id="adminQuestionList"></div>
      </div>
      <div class="card" style="position: sticky; top: 90px; align-self: start;">
        <h4 style="font-size:16px; margin-bottom:16px"><i class="fas fa-plus-circle" style="color:var(--accent); margin-right:8px"></i>Add Question</h4>
        <form onsubmit="App.addQuestion(event)">
          <div class="form-group"><label>Question Text</label><textarea class="textarea" id="qText" required placeholder="Type question..." rows="3"></textarea></div>
          <div class="form-group"><label>Options <span style="font-size:11px; font-weight:normal; color:var(--txt2)">(select correct)</span></label>
            <div style="display:flex; flex-direction:column; gap:8px">
              <div class="flex items-center gap-1"><input class="input" id="qOpt0" required placeholder="Option A"><input type="radio" name="correctOpt" value="0" checked style="width:20px;height:20px"></div>
              <div class="flex items-center gap-1"><input class="input" id="qOpt1" required placeholder="Option B"><input type="radio" name="correctOpt" value="1" style="width:20px;height:20px"></div>
              <div class="flex items-center gap-1"><input class="input" id="qOpt2" placeholder="Option C (optional)"><input type="radio" name="correctOpt" value="2" style="width:20px;height:20px"></div>
              <div class="flex items-center gap-1"><input class="input" id="qOpt3" placeholder="Option D (optional)"><input type="radio" name="correctOpt" value="3" style="width:20px;height:20px"></div>
            </div>
          </div>
          <div class="form-group"><label>Marks</label><input class="input" type="number" id="qMarks" min="1" value="1" style="width:100px"></div>
          <button class="btn btn-primary w-full" type="submit">Add Question</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- ═══ ADMIN SUBMISSIONS ═══ -->
<section class="view" id="view-admin-subs">
  <div class="container">
    <button class="btn btn-ghost mb-3" onclick="App.navigate('admin')"><i class="fas fa-arrow-left"></i> Back</button>
    <div id="adminSubsContent"></div>
  </div>
</section>

<!-- ═══ STUDENT DASHBOARD ═══ -->
<section class="view" id="view-student">
  <div class="container">
    <div class="mb-3"><h2 style="font-size:32px;">Student Dashboard</h2><p style="color:var(--txt2)">Browse available exams and track progress</p></div>
    <div class="grid-3 mb-3" id="studentStats"></div>
    <h3 style="font-size:20px; margin-bottom:16px">Available Exams</h3>
    <div id="studentExamList"></div>
  </div>
</section>

<!-- ═══ STUDENT TAKE EXAM ═══ -->
<section class="view" id="view-exam-take">
  <div class="container">
    <div id="examTakeContent"></div>
  </div>
</section>

<!-- ═══ STUDENT RESULTS ═══ -->
<section class="view" id="view-student-results">
  <div class="container">
    <button class="btn btn-ghost mb-3" onclick="App.navigate('student')"><i class="fas fa-arrow-left"></i> Back</button>
    <h2 style="font-size:32px; margin-bottom:24px">My Results</h2>
    <div id="studentResultsList"></div>
  </div>
</section>

<!-- ═══ STUDENT RESULT DETAIL ═══ -->
<section class="view" id="view-student-result-detail">
  <div class="container" style="max-width:800px">
    <button class="btn btn-ghost mb-3" onclick="App.navigate('student-results')"><i class="fas fa-arrow-left"></i> Back to Results</button>
    <div id="resultDetailContent"></div>
  </div>
</section>

<script>
const App = {
  user: <%- JSON.stringify(user || null) %>,
  currentView: 'auth',
  currentExam: null,
  currentSubmission: null,
  currentQuestionIdx: 0,
  flagged: new Set(),
  timerInterval: null,
  timeRemaining: 0,
  saveInterval: null,

  init() {
    if (this.user) {
      this.showNav();
      this.navigate(this.user.role === 'admin' ? 'admin' : 'student');
    } else {
      this.navigate('auth');
    }
  },

  navigate(view) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    const el = document.getElementById('view-' + view);
    if (el) { el.classList.add('active'); this.currentView = view; }
    this.updateNav(view);
    
    if (view === 'admin') this.loadAdminDashboard();
    if (view === 'student') this.loadStudentDashboard();
    if (view === 'student-results') this.loadStudentResults();
    
    if (view !== 'exam-take') { this.stopTimer(); clearInterval(this.saveInterval); }
  },

  showNav() {
    document.getElementById('mainNav').classList.remove('hidden');
    document.getElementById('navName').textContent = this.user.name;
    const re = document.getElementById('navRole');
    re.textContent = this.user.role;
    re.className = `nav-role ${this.user.role}`;
  },

  updateNav(active) {
    const links = document.getElementById('navLinks');
    if (this.user.role === 'admin') {
      links.innerHTML = `<button class="nav-link ${active === 'admin' ? 'active' : ''}" onclick="App.navigate('admin')"><i class="fas fa-tachometer-alt"></i> Dashboard</button>`;
    } else {
      links.innerHTML = `
        <button class="nav-link ${active === 'student' ? 'active' : ''}" onclick="App.navigate('student')"><i class="fas fa-book-open"></i> Exams</button>
        <button class="nav-link ${active === 'student-results' ? 'active' : ''}" onclick="App.navigate('student-results')"><i class="fas fa-chart-bar"></i> Results</button>
      `;
    }
  },

  switchAuth(tab) {
    document.querySelectorAll('.auth-tab').forEach((t, i) => t.classList.toggle('active', (tab === 'login' ? 0 : 1) === i));
    document.getElementById('form-login').classList.toggle('active', tab === 'login');
    document.getElementById('form-register').classList.toggle('active', tab === 'register');
  },

  async login(e) {
    e.preventDefault();
    const email = document.getElementById('loginEmail').value;
    const password = document.getElementById('loginPass').value;
    const res = await this.api('/api/login', 'POST', { email, password });
    if (res.error) return this.toast(res.error, 'error');
    this.user = res.user;
    this.showNav();
    this.navigate(this.user.role === 'admin' ? 'admin' : 'student');
    this.toast(`Welcome back, ${this.user.name}`, 'success');
  },

  async register(e) {
    e.preventDefault();
    const body = { 
      name: document.getElementById('regName').value, 
      email: document.getElementById('regEmail').value, 
      password: document.getElementById('regPass').value, 
      role: document.getElementById('regRole').value 
    };
    const res = await this.api('/api/register', 'POST', body);
    if (res.error) return this.toast(res.error, 'error');
    this.user = res.user;
    this.showNav();
    this.navigate(this.user.role === 'admin' ? 'admin' : 'student');
    this.toast(`Account created! Welcome, ${this.user.name}`, 'success');
  },

  async logout() {
    await this.api('/api/logout', 'POST');
    this.user = null;
    document.getElementById('mainNav').classList.add('hidden');
    this.navigate('auth');
    this.toast('Logged out successfully', 'info');
  },

  async seed() {
    const res = await this.api('/api/seed', 'POST');
    if (res.error) return this.toast(res.error, 'error');
    this.toast(res.message, 'success');
  },

  async loadAdminDashboard() {
    const res = await this.api('/api/admin/exams');
    if (res.error) return;
    const exams = res.exams || [];
    const totalQ = exams.reduce((s, e) => s + e.questions.length, 0);
    const totalSubs = exams.reduce((s, e) => s + e.submissionCount, 0);
    
    document.getElementById('adminStats').innerHTML = `
      <div class="card stat-card"><div class="stat-icon" style="background:var(--accent-glow);color:var(--accent)"><i class="fas fa-file-alt"></i></div><div class="stat-val">${exams.length}</div><div class="stat-label">Total Exams</div></div>
      <div class="card stat-card"><div class="stat-icon" style="background:var(--warn-l);color:var(--warn)"><i class="fas fa-question-circle"></i></div><div class="stat-val">${totalQ}</div><div class="stat-label">Total Questions</div></div>
      <div class="card stat-card"><div class="stat-icon" style="background:var(--success-l);color:var(--success)"><i class="fas fa-users"></i></div><div class="stat-val">${totalSubs}</div><div class="stat-label">Submissions</div></div>
    `;

    if (!exams.length) {
      document.getElementById('adminExamList').innerHTML = `<div class="card text-center" style="padding:60px 20px; color:var(--txt2)"><i class="fas fa-folder-open" style="font-size:48px; opacity:0.5; margin-bottom:16px"></i><h3>No exams yet</h3><p>Create your first exam to get started</p></div>`;
      return;
    }
    document.getElementById('adminExamList').innerHTML = exams.map(e => `
      <div class="card exam-card">
        <div class="exam-info">
          <h3>${this.esc(e.title)}</h3>
          <div class="exam-meta">
            <span><i class="fas fa-clock"></i> ${e.duration} min</span>
            <span><i class="fas fa-list-ol"></i> ${e.questions.length} Qs</span>
            <span><i class="fas fa-users"></i> ${e.submissionCount} submissions</span>
            <span class="badge ${e.isActive ? 'badge-active' : 'badge-inactive'}">${e.isActive ? 'Active' : 'Inactive'}</span>
          </div>
        </div>
        <div class="exam-actions">
          <button class="btn btn-sm btn-secondary" onclick="App.viewExamDetail('${e._id}')"><i class="fas fa-edit"></i> Manage</button>
          <button class="btn btn-sm ${e.isActive ? 'btn-secondary' : 'btn-success'}" onclick="App.toggleExam('${e._id}')">${e.isActive ? 'Deactivate' : 'Activate'}</button>
          <button class="btn btn-sm btn-secondary" onclick="App.viewSubmissions('${e._id}')"><i class="fas fa-chart-bar"></i> Results</button>
          <button class="btn btn-sm btn-danger btn-icon" onclick="App.deleteExam('${e._id}','${this.esc(e.title)}')"><i class="fas fa-trash"></i></button>
        </div>
      </div>
    `).join('');
  },

  showCreateExam() { this.navigate('admin-create'); },

  async createExam(e) {
    e.preventDefault();
    const body = { 
      title: document.getElementById('examTitle').value, 
      description: document.getElementById('examDesc').value, 
      duration: parseInt(document.getElementById('examDuration').value), 
      passingPercentage: parseInt(document.getElementById('examPassPct').value) 
    };
    const res = await this.api('/api/admin/exams', 'POST', body);
    if (res.error) return this.toast(res.error, 'error');
    this.toast('Exam created successfully', 'success');
    this.viewExamDetail(res.exam._id);
  },

  async viewExamDetail(id) {
    const res = await this.api(`/api/admin/exams/${id}`);
    if (res.error) return this.toast(res.error, 'error');
    this.currentExam = res.exam;
    this.navigate('admin-exam');
    this.renderExamHeader();
    this.renderAdminQuestions();
  },

  renderExamHeader() {
    const e = this.currentExam;
    document.getElementById('adminExamHeader').innerHTML = `
      <div class="card flex justify-between items-center" style="gap:16px; flex-wrap:wrap">
        <div>
          <h2 style="font-size:28px">${this.esc(e.title)}</h2>
          <p style="color:var(--txt2); margin-top:4px">${this.esc(e.description || 'No description')} &middot; ${e.duration} min &middot; Pass: ${e.passingPercentage}%</p>
        </div>
        <span class="badge ${e.isActive ? 'badge-active' : 'badge-inactive'}">${e.isActive ? 'Active' : 'Inactive'}</span>
      </div>`;
  },

  renderAdminQuestions() {
    const qs = this.currentExam.questions;
    document.getElementById('qCountLabel').textContent = `${qs.length} question${qs.length !== 1 ? 's' : ''}`;
    if (!qs.length) {
      document.getElementById('adminQuestionList').innerHTML = `<div class="card text-center" style="padding:40px; color:var(--txt2)"><i class="fas fa-plus-circle" style="font-size:32px; margin-bottom:12px; opacity:0.5"></i><h3>No questions yet</h3><p>Use the form on the right to add some.</p></div>`;
      return;
    }
    const letters = ['A','B','C','D'];
    document.getElementById('adminQuestionList').innerHTML = qs.map((q, i) => `
      <div class="card mb-2" style="padding:20px;">
        <div class="flex justify-between items-center mb-2">
          <span style="font-weight:700; color:var(--accent)">Q${i+1} &middot; ${q.marks} mark${q.marks > 1 ? 's' : ''}</span>
          <button class="btn btn-sm btn-danger btn-icon" onclick="App.deleteQuestion('${this.currentExam._id}', ${i})"><i class="fas fa-trash"></i></button>
        </div>
        <div style="font-size:16px; margin-bottom:16px">${this.esc(q.questionText)}</div>
        <div class="grid-2">
          ${q.options.map((o, oi) => `
            <div style="padding:10px 14px; border-radius:8px; background:rgba(0,0,0,0.2); border:1px solid ${oi === q.correctAnswer ? 'var(--success)' : 'var(--card-border)'}; display:flex; gap:10px; align-items:center;">
              <span style="font-weight:700; color:var(--txt2)">${letters[oi]}.</span>
              <span style="flex:1">${this.esc(o)}</span>
              ${oi === q.correctAnswer ? '<i class="fas fa-check-circle" style="color:var(--success)"></i>' : ''}
            </div>
          `).join('')}
        </div>
      </div>
    `).join('');
  },

  async addQuestion(e) {
    e.preventDefault();
    const opts = [
      document.getElementById('qOpt0').value.trim(), 
      document.getElementById('qOpt1').value.trim(), 
      document.getElementById('qOpt2').value.trim(), 
      document.getElementById('qOpt3').value.trim()
    ].filter(o => o);
    
    const correctNode = document.querySelector('input[name="correctOpt"]:checked');
    const correctIdx = correctNode ? parseInt(correctNode.value) : 0;
    
    if (opts.length < 2) return this.toast('Need at least 2 options', 'error');
    if (correctIdx >= opts.length) return this.toast('Correct answer points to empty option', 'error');
    
    const body = { 
      questionText: document.getElementById('qText').value, 
      options: opts, 
      correctAnswer: correctIdx, 
      marks: parseInt(document.getElementById('qMarks').value) || 1 
    };
    
    const res = await this.api(`/api/admin/exams/${this.currentExam._id}/questions`, 'POST', body);
    if (res.error) return this.toast(res.error, 'error');
    this.currentExam = res.exam;
    this.renderAdminQuestions();
    
    // Reset Form
    e.target.reset();
    document.querySelector('input[name="correctOpt"][value="0"]').checked = true;
    this.toast('Question added successfully', 'success');
  },

  async deleteQuestion(examId, qi) {
    if (!confirm('Are you sure you want to delete this question?')) return;
    const res = await this.api(`/api/admin/exams/${examId}/questions/${qi}`, 'DELETE');
    if (res.error) return this.toast(res.error, 'error');
    this.currentExam = res.exam;
    this.renderExamHeader();
    this.renderAdminQuestions();
    this.toast('Question deleted', 'info');
  },

  async toggleExam(id) {
    const res = await this.api(`/api/admin/exams/${id}/toggle`, 'PATCH');
    if (res.error) return this.toast(res.error, 'error');
    this.loadAdminDashboard();
    this.toast(`Exam ${res.exam.isActive ? 'activated' : 'deactivated'}`, 'success');
  },

  deleteExam(id, title) {
    this.showModal('Delete Exam', `Type carefully: Are you sure you want to delete "${title}"? All submissions will also be erased.`, async () => {
      const res = await this.api(`/api/admin/exams/${id}`, 'DELETE');
      if (res.error) return this.toast(res.error, 'error');
      this.loadAdminDashboard();
      this.navigate('admin');
      this.toast('Exam deleted permanently', 'info');
    });
  },

  async viewSubmissions(id) {
    const res = await this.api(`/api/admin/exams/${id}/submissions`);
    if (res.error) return this.toast(res.error, 'error');
    this.navigate('admin-subs');
    const { exam, submissions: subs } = res;
    
    const avgPct = subs.length ? Math.round(subs.reduce((s, x) => s + x.percentage, 0) / subs.length) : 0;
    const passCount = subs.filter(s => s.passed).length;
    
    document.getElementById('adminSubsContent').innerHTML = `
      <div class="mb-3">
        <h2 style="font-size:28px">${this.esc(exam.title)}</h2>
        <p style="color:var(--txt2)">Results & Analysis</p>
      </div>
      <div class="grid-3 mb-3">
        <div class="card stat-card"><div class="stat-icon" style="background:var(--accent-glow);color:var(--accent)"><i class="fas fa-users"></i></div><div class="stat-val">${subs.length}</div><div class="stat-label">Submissions</div></div>
        <div class="card stat-card"><div class="stat-icon" style="background:var(--success-l);color:var(--success)"><i class="fas fa-percentage"></i></div><div class="stat-val">${avgPct}%</div><div class="stat-label">Average Score</div></div>
        <div class="card stat-card"><div class="stat-icon" style="background:var(--warn-l);color:var(--warn)"><i class="fas fa-check-double"></i></div><div class="stat-val">${passCount}/${subs.length}</div><div class="stat-label">Passed</div></div>
      </div>
      ${!subs.length ? `<div class="card text-center" style="padding:40px;color:var(--txt2)"><i class="fas fa-inbox" style="font-size:32px;opacity:0.5;margin-bottom:12px"></i><h3>No submissions yet</h3></div>` : `
      <div class="table-wrap">
        <table>
          <thead><tr><th>Student</th><th>Score</th><th>Percentage</th><th>Time</th><th>Status</th><th>Submitted</th></tr></thead>
          <tbody>
            ${subs.map(s => `
              <tr>
                <td><strong>${this.esc(s.user.name)}</strong><br><span style="font-size:12px;color:var(--txt2)">${this.esc(s.user.email)}</span></td>
                <td><strong style="color:var(--accent)">${s.score}</strong>/${s.totalMarks}</td>
                <td>${s.percentage}%</td>
                <td>${this.fmtTime(s.timeTaken)}</td>
                <td><span class="badge ${s.passed ? 'badge-pass' : 'badge-fail'}">${s.passed ? 'Pass' : 'Fail'}</span></td>
                <td style="font-size:13px;color:var(--txt2)">${new Date(s.submittedAt).toLocaleString()}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>`}
    `;
  },

  async loadStudentDashboard() {
    const [examRes, resultRes] = await Promise.all([
      this.api('/api/student/exams'), 
      this.api('/api/student/results')
    ]);
    if (examRes.error) return;
    
    const exams = examRes.exams || [];
    const submissions = (resultRes.submissions || []).filter(s => s.exam);
    const totalTaken = submissions.length;
    const avgPct = totalTaken ? Math.round(submissions.reduce((s, x) => s + x.percentage, 0) / totalTaken) : 0;
    
    document.getElementById('studentStats').innerHTML = `
      <div class="card stat-card"><div class="stat-icon" style="background:var(--accent-glow);color:var(--accent)"><i class="fas fa-file-alt"></i></div><div class="stat-val">${exams.length}</div><div class="stat-label">Available Exams</div></div>
      <div class="card stat-card"><div class="stat-icon" style="background:var(--success-l);color:var(--success)"><i class="fas fa-check-circle"></i></div><div class="stat-val">${totalTaken}</div><div class="stat-label">Completed</div></div>
      <div class="card stat-card"><div class="stat-icon" style="background:var(--warn-l);color:var(--warn)"><i class="fas fa-trophy"></i></div><div class="stat-val">${avgPct}%</div><div class="stat-label">Average Score</div></div>
    `;

    if (!exams.length) {
      document.getElementById('studentExamList').innerHTML = `<div class="card text-center" style="padding:50px;color:var(--txt2)"><i class="fas fa-book-open" style="font-size:40px;opacity:0.5;margin-bottom:12px"></i><h3>No exams available</h3><p>Check back later.</p></div>`;
      return;
    }
    document.getElementById('studentExamList').innerHTML = exams.map(e => `
      <div class="card exam-card">
        <div class="exam-info">
          <h3>${this.esc(e.title)}</h3>
          <div class="exam-meta">
            <span><i class="fas fa-clock"></i> ${e.duration} min</span>
            <span><i class="fas fa-list-ol"></i> ${e.questionCount} Qs</span>
            <span><i class="fas fa-user-tie"></i> ${this.esc(e.createdBy?.name || 'Instructor')}</span>
          </div>
        </div>
        <div class="exam-actions">
          ${e.hasSubmitted 
            ? `<span class="badge badge-active" style="padding:6px 14px"><i class="fas fa-check"></i> Completed</span>` 
            : (e.questionCount > 0 
                ? `<button class="btn btn-primary" onclick="App.confirmStartExam('${e._id}')"><i class="fas fa-play"></i> Start Exam</button>` 
                : `<span style="color:var(--txt2);font-size:13px">No questions yet</span>`)}
        </div>
      </div>
    `).join('');
  },

  confirmStartExam(id) {
    this.showModal('Start Exam', 'The timer will begin immediately and cannot be paused. Ensure you have a stable connection. Ready to start?', () => this.startExam(id));
  },

  async startExam(id) {
    const res = await this.api(`/api/student/exams/${id}/start`, 'POST');
    if (res.error) return this.toast(res.error, 'error');
    this.currentExam = res.exam;
    this.currentSubmission = res.submission;
    this.currentQuestionIdx = 0;
    this.flagged = new Set();
    this.navigate('exam-take');
    
    const elapsed = Math.floor((Date.now() - new Date(this.currentSubmission.startedAt).getTime()) / 1000);
    this.timeRemaining = this.currentExam.duration * 60 - elapsed;
    this.startTimer();
    this.renderExamTake();
    this.saveInterval = setInterval(() => this.autoSave(), 30000);
  },

  renderExamTake() {
    const exam = this.currentExam;
    const qs = exam.questions;
    const q = qs[this.currentQuestionIdx];
    const answers = this.currentSubmission.answers || [];
    const selected = answers[this.currentQuestionIdx] ? answers[this.currentQuestionIdx].selectedAnswer : -1;
    const letters = ['A', 'B', 'C', 'D'];

    document.getElementById('examTakeContent').innerHTML = `
      <div class="exam-header">
        <div>
          <h3 style="font-size:24px; margin-bottom:4px">${this.esc(exam.title)}</h3>
          <p style="color:var(--txt2); font-size:14px">${qs.length} questions &middot; ${exam.duration} minutes total</p>
        </div>
        <div class="timer" id="examTimer">
          <i class="fas fa-stopwatch"></i><span id="timerDisplay">${this.fmtTime(this.timeRemaining)}</span>
        </div>
      </div>
      
      <div class="exam-body">
        <div class="q-nav">
          <h4 style="color:var(--txt2); margin-bottom:16px; font-size:13px; text-transform:uppercase; letter-spacing:1px">Question Map</h4>
          <div class="q-nav-grid">
            ${qs.map((_, i) => {
              let cls = '';
              const a = answers[i]?.selectedAnswer;
              if (i === this.currentQuestionIdx) cls = 'current';
              else if (this.flagged.has(i)) cls = 'flagged';
              else if (a !== undefined && a > -1) cls = 'answered';
              return `<button class="q-nav-btn ${cls}" onclick="App.goToQuestion(${i})">${i+1}</button>`;
            }).join('')}
          </div>
          <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--card-border); display:flex; flex-direction:column; gap:8px; font-size:13px; color:var(--txt2)">
            <div><span style="display:inline-block; width:12px; height:12px; border-radius:3px; background:var(--accent); margin-right:8px"></span> Current</div>
            <div><span style="display:inline-block; width:12px; height:12px; border-radius:3px; background:var(--success-l); border:1px solid var(--success); margin-right:8px"></span> Answered</div>
            <div><span style="display:inline-block; width:12px; height:12px; border-radius:3px; background:var(--warn-l); border:1px solid var(--warn); margin-right:8px"></span> Flagged</div>
          </div>
        </div>
        
        <div class="q-display">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; color:var(--txt2); font-size:14px; border-bottom:1px solid var(--card-border); padding-bottom:16px;">
            <span>Question ${this.currentQuestionIdx + 1} of ${qs.length}</span>
            <button class="btn btn-sm btn-ghost" onclick="App.toggleFlag(${this.currentQuestionIdx})">
              <i class="${this.flagged.has(this.currentQuestionIdx) ? 'fas fa-flag' : 'far fa-flag'}" style="color:${this.flagged.has(this.currentQuestionIdx) ? 'var(--warn)' : 'inherit'}"></i> 
              ${this.flagged.has(this.currentQuestionIdx) ? 'Flagged for Review' : 'Flag Question'}
            </button>
          </div>
          
          <div class="q-title">
            ${this.esc(q.questionText)}
            <span style="font-size:12px; background:rgba(0,0,0,0.3); color:var(--txt2); padding:4px 8px; border-radius:4px; margin-left:12px; font-weight:600; vertical-align:middle;">${q.marks} Mark${q.marks > 1 ? 's' : ''}</span>
          </div>
          
          <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:40px;">
            ${q.options.map((o, i) => `
              <div class="option-item ${selected === i ? 'selected' : ''}" onclick="App.selectOption(${i})">
                <div class="option-radio"></div>
                <span style="font-weight:700; color:var(--txt2); width:20px">${letters[i]}.</span>
                <span style="flex:1">${this.esc(o)}</span>
              </div>
            `).join('')}
          </div>
          
          <div class="q-nav-footer">
            <button class="btn btn-secondary" ${this.currentQuestionIdx === 0 ? 'disabled style="opacity:0.4; cursor:not-allowed"' : ''} onclick="App.goToQuestion(${this.currentQuestionIdx - 1})"><i class="fas fa-arrow-left"></i> Previous</button>
            <div class="flex gap-2">
              ${this.currentQuestionIdx < qs.length - 1 
                ? `<button class="btn btn-secondary" onclick="App.goToQuestion(${this.currentQuestionIdx + 1})">Next <i class="fas fa-arrow-right"></i></button>`
                : ''}
              <button class="btn btn-success" onclick="App.confirmSubmit()"><i class="fas fa-check-double"></i> Submit Exam</button>
            </div>
          </div>
        </div>
      </div>
    `;
  },

  selectOption(idx) {
    if (!this.currentSubmission.answers) this.currentSubmission.answers = this.currentExam.questions.map((_, i) => ({ questionIndex: i, selectedAnswer: -1 }));
    this.currentSubmission.answers[this.currentQuestionIdx] = { questionIndex: this.currentQuestionIdx, selectedAnswer: idx };
    this.renderExamTake();
  },

  goToQuestion(idx) {
    if (idx < 0 || idx >= this.currentExam.questions.length) return;
    this.currentQuestionIdx = idx;
    this.renderExamTake();
  },

  toggleFlag(idx) {
    if (this.flagged.has(idx)) this.flagged.delete(idx); 
    else this.flagged.add(idx);
    this.renderExamTake();
  },

  startTimer() {
    this.stopTimer();
    this.timerInterval = setInterval(() => {
      this.timeRemaining--;
      const display = document.getElementById('timerDisplay');
      const timer = document.getElementById('examTimer');
      if (display) display.textContent = this.fmtTime(Math.max(0, this.timeRemaining));
      if (timer) { 
        timer.classList.remove('warning', 'danger'); 
        if (this.timeRemaining <= 60) timer.classList.add('danger'); 
        else if (this.timeRemaining <= 300) timer.classList.add('warning'); 
      }
      if (this.timeRemaining <= 0) { 
        this.stopTimer(); 
        this.toast('Time is up! Auto-submitting...', 'warn'); 
        this.submitExam(); 
      }
    }, 1000);
  },

  stopTimer() { 
    if (this.timerInterval) { clearInterval(this.timerInterval); this.timerInterval = null; } 
  },

  async autoSave() {
    if (!this.currentSubmission || this.currentView !== 'exam-take') return;
    await this.api(`/api/student/submissions/${this.currentSubmission._id}/save`, 'PUT', { answers: this.currentSubmission.answers });
  },

  confirmSubmit() {
    const answers = this.currentSubmission.answers || [];
    const unanswered = answers.filter(a => a.selectedAnswer === -1 || a.selectedAnswer === undefined).length;
    const msg = unanswered > 0 ? `You have <strong style="color:var(--warn)">${unanswered} unanswered</strong> question(s). ` : '';
    this.showModal('Confirm Submission', msg + 'Are you sure you want to turn in your exam? This cannot be undone.', () => this.submitExam());
  },

  async submitExam() {
    this.stopTimer();
    clearInterval(this.saveInterval);
    const res = await this.api(`/api/student/submissions/${this.currentSubmission._id}/submit`, 'POST', { answers: this.currentSubmission.answers });
    if (res.error) return this.toast(res.error, 'error');
    this.showResult(res.result);
  },

  showResult(result) {
    const pct = result.percentage;
    const passed = result.passed;
    const circumference = 2 * Math.PI * 72; /* 72 is r of circle */
    const offset = circumference - (pct / 100) * circumference;
    
    document.getElementById('examTakeContent').innerHTML = `
      <div class="result-hero card-glow">
        <div class="score-circle">
          <svg viewBox="0 0 160 160">
            <circle class="bg-ring" cx="80" cy="80" r="72" />
            <circle class="fg-ring ${passed ? '' : 'fail'}" cx="80" cy="80" r="72" stroke-dasharray="${circumference}" stroke-dashoffset="${circumference}" id="takeResultRing" />
          </svg>
          <div class="score-val">${pct}%</div>
          <div class="score-label" style="color:var(--txt2); font-weight:600">SCORE</div>
        </div>
        <div class="result-status ${passed ? 'pass' : 'fail'}">${passed ? 'PASSED' : 'FAILED'}</div>
        <p style="color:var(--txt2); margin-bottom:32px; font-size:16px">You scored <strong>${result.score}</strong> out of ${result.totalMarks} marks</p>
        
        <div class="grid-3" style="max-width:500px; margin:0 auto; gap:24px">
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700; color:var(--success)">${result.score}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Correct</div></div>
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700; color:var(--danger)">${result.totalMarks - result.score}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Incorrect</div></div>
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700">${this.fmtTime(result.timeTaken)}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Time Taken</div></div>
        </div>
      </div>
      <div class="text-center mt-3">
        <button class="btn btn-primary btn-lg" onclick="App.navigate('student-results')"><i class="fas fa-chart-line"></i> View Detailed Analytics</button>
      </div>
    `;
    
    requestAnimationFrame(() => {
      setTimeout(() => {
        const ring = document.getElementById('takeResultRing');
        if (ring) ring.style.strokeDashoffset = offset;
      }, 100);
    });
  },

  async loadStudentResults() {
    const res = await this.api('/api/student/results');
    if (res.error) return;
    const subs = (res.submissions || []).filter(s => s.exam);
    if (!subs.length) {
      document.getElementById('studentResultsList').innerHTML = `<div class="card text-center" style="padding:60px 20px; color:var(--txt2)"><i class="fas fa-chart-bar" style="font-size:48px; opacity:0.5; margin-bottom:16px"></i><h3>No results yet</h3><p>Complete an exam to see your performance here.</p></div>`;
      return;
    }
    
    document.getElementById('studentResultsList').innerHTML = subs.map(s => `
      <div class="card exam-card" style="cursor:pointer" onclick="App.viewResultDetail('${s._id}')">
        <div class="exam-info">
          <h3>${this.esc(s.exam.title)}</h3>
          <div class="exam-meta">
            <span><i class="fas fa-bullseye"></i> ${s.percentage}% Score</span>
            <span><i class="fas fa-stopwatch"></i> ${this.fmtTime(s.timeTaken)}</span>
            <span class="badge ${s.passed ? 'badge-pass' : 'badge-fail'}">${s.passed ? 'Pass' : 'Fail'}</span>
          </div>
        </div>
        <div class="exam-actions">
          <button class="btn btn-sm btn-secondary"><i class="fas fa-arrow-right"></i> Review</button>
        </div>
      </div>
    `).join('');
  },

  async viewResultDetail(id) {
    const res = await this.api(`/api/student/submissions/${id}`);
    if (res.error) return this.toast(res.error, 'error');
    this.navigate('student-result-detail');
    
    const sub = res.submission;
    const exam = sub.exam;
    const qs = exam.questions || [];
    const answers = sub.answers || [];
    const letters = ['A', 'B', 'C', 'D'];

    const circumference = 2 * Math.PI * 72;
    const offset = circumference - (sub.percentage / 100) * circumference;

    let html = `
      <div class="result-hero card-glow">
        <div class="score-circle">
          <svg viewBox="0 0 160 160">
            <circle class="bg-ring" cx="80" cy="80" r="72" />
            <circle class="fg-ring ${sub.passed ? '' : 'fail'}" cx="80" cy="80" r="72" stroke-dasharray="${circumference}" stroke-dashoffset="${circumference}" id="detailResultRing" />
          </svg>
          <div class="score-val">${sub.percentage}%</div>
          <div class="score-label" style="color:var(--txt2); font-weight:600">SCORE</div>
        </div>
        <div class="result-status ${sub.passed ? 'pass' : 'fail'}">${sub.passed ? 'PASSED' : 'FAILED'}</div>
        <p style="color:var(--txt2); margin-bottom:32px">Scored <strong>${sub.score}</strong> out of ${sub.totalMarks} marks</p>
        
        <div class="grid-3" style="max-width:500px; margin:0 auto; gap:24px">
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700; color:var(--success)">${sub.score}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Correct</div></div>
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700; color:var(--danger)">${sub.totalMarks - sub.score}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Incorrect</div></div>
          <div class="card" style="padding:16px"><div style="font-size:24px; font-weight:700">${this.fmtTime(sub.timeTaken)}</div><div style="font-size:12px; color:var(--txt2); text-transform:uppercase; font-weight:600">Time</div></div>
        </div>
      </div>
      <h3 style="font-size:24px; margin:32px 0 20px;">Detailed Breakdown</h3>
    `;

    html += qs.map((q, i) => {
      const ans = answers.find(a => a.questionIndex === i) || {};
      const selected = ans.selectedAnswer !== undefined ? ans.selectedAnswer : -1;
      const isCorrect = selected === q.correctAnswer;
      
      return `
        <div class="card mb-2" style="border-left: 4px solid ${isCorrect ? 'var(--success)' : (selected === -1 ? 'var(--muted)' : 'var(--danger)')}">
          <div class="flex justify-between items-center mb-2">
            <span style="font-weight:700; color:var(--accent)">Q${i+1} &middot; ${q.marks} mark${q.marks > 1 ? 's' : ''}</span>
            <span class="badge ${isCorrect ? 'badge-pass' : (selected === -1 ? '' : 'badge-fail')}" style="background:${selected === -1 ? 'var(--elevated)' : ''}">${isCorrect ? 'Correct' : (selected === -1 ? 'Skipped' : 'Incorrect')}</span>
          </div>
          <div style="font-size:16px; margin-bottom:16px">${this.esc(q.questionText)}</div>
          <div class="grid-2">
            ${q.options.map((o, oi) => {
              let bg = 'rgba(0,0,0,0.2)';
              let border = 'var(--card-border)';
              let icon = '';
              
              if (oi === q.correctAnswer) {
                bg = 'var(--success-l)'; border = 'var(--success)'; icon = '<i class="fas fa-check-circle" style="color:var(--success)"></i>';
              } else if (oi === selected) {
                bg = 'var(--danger-l)'; border = 'var(--danger)'; icon = '<i class="fas fa-times-circle" style="color:var(--danger)"></i>';
              }
              
              return `
                <div style="padding:12px 16px; border-radius:8px; background:${bg}; border:1px solid ${border}; display:flex; gap:10px; align-items:center;">
                  <span style="font-weight:700; color:var(--txt2)">${letters[oi]}.</span>
                  <span style="flex:1">${this.esc(o)}</span>
                  ${icon}
                </div>
              `;
            }).join('')}
          </div>
        </div>
      `;
    }).join('');

    document.getElementById('resultDetailContent').innerHTML = html;

    requestAnimationFrame(() => {
      setTimeout(() => {
        const ring = document.getElementById('detailResultRing');
        if (ring) ring.style.strokeDashoffset = offset;
      }, 100);
    });
  },

  // Helpers
  async api(url, method = 'GET', body = null) {
    try {
      const opts = { method, headers: { 'Content-Type': 'application/json' } };
      if (body) opts.body = JSON.stringify(body);
      const res = await fetch(url, opts);
      return await res.json();
    } catch (e) { 
      return { error: 'Network error. Please check your connection.' }; 
    }
  },

  esc(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  },

  fmtTime(secs) {
    if (secs === undefined || secs === null) return '-';
    const m = Math.floor(Math.max(0, secs) / 60);
    const s = Math.max(0, secs) % 60;
    return `${m}m ${s < 10 ? '0' : ''}${s}s`;
  },

  toast(msg, type = 'info') {
    const wrap = document.getElementById('toastWrap');
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    const icons = { success: 'check-circle', error: 'exclamation-circle', warn: 'exclamation-triangle', info: 'info-circle' };
    el.innerHTML = `<i class="fas fa-${icons[type] || 'info-circle'}"></i> ${msg}`;
    wrap.appendChild(el);
    setTimeout(() => { 
      el.style.opacity = '0'; 
      el.style.transform = 'translateX(50px)'; 
      setTimeout(() => el.remove(), 300); 
    }, 4000);
  },

  showModal(title, msg, onConfirm) {
    const wrap = document.getElementById('modalWrap');
    wrap.innerHTML = `
      <div class="modal-overlay" onclick="App.closeModal(event)">
        <div class="modal-box" onclick="event.stopPropagation()">
          <h3>${title}</h3>
          <p>${msg}</p>
          <div class="modal-actions">
            <button class="btn btn-secondary" onclick="App.closeModal()">Cancel</button>
            <button class="btn btn-primary" id="modalConfirmBtn">Confirm</button>
          </div>
        </div>
      </div>
    `;
    document.getElementById('modalConfirmBtn').onclick = () => { onConfirm(); App.closeModal(); };
  },

  closeModal(e) {
    if (e && e.target !== e.currentTarget) return;
    document.getElementById('modalWrap').innerHTML = '';
  }
};

document.addEventListener('DOMContentLoaded', () => App.init());
</script>

</body>
</html>
